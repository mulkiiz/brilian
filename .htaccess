# =====================================================
# Brilian 2026 - Konfirmasi Desa
# Defensive .htaccess untuk shared hosting cPanel
# =====================================================

# Force HTTPS (hanya jika mod_rewrite aktif)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP:X-Forwarded-Proto} !=https
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Security headers (hanya jika mod_headers aktif)
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Block direct access ke file sensitif
<FilesMatch "\.(sql|md)$">
    Order allow,deny
    Deny from all
</FilesMatch>

<Files "config.php">
    Order allow,deny
    Deny from all
</Files>

# Disable directory listing
Options -Indexes

# Default file
DirectoryIndex index.php index.html
